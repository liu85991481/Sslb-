# Kimi (御史台 - 长上下文终审)
KIMI_API_KEY=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
